<Window x:Class="CursorShake.AnnotationCanvasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Focusable="True"
        Loaded="Window_OnLoaded"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
  <Window.Resources>
    <Style x:Key="AnnToolBtn" TargetType="Button">
      <Setter Property="FontFamily" Value="Space Mono, Consolas" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="#999999" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#E8E8E8" />
          <Setter Property="BorderBrush" Value="#666666" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="PrtMenuItem" TargetType="Button" BasedOn="{StaticResource AnnToolBtn}">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style x:Key="SwatchBtn" TargetType="Button">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="SwBd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid x:Name="RootGrid" Background="#01000000">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="0">
      <Border HorizontalAlignment="Center"
              MaxWidth="860"
              Background="#111111"
              BorderBrush="#333333"
              BorderThickness="1"
              Padding="12,10,12,10"
              CornerRadius="0,0,6,6">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="BtnLine"
                  Content="LINE"
                  Style="{StaticResource AnnToolBtn}"
                  Click="BtnLine_OnClick" />
          <Button x:Name="BtnArrow"
                  Content="ARROW"
                  Style="{StaticResource AnnToolBtn}"
                  Margin="8,0,0,0"
                  Click="BtnArrow_OnClick" />
          <Button x:Name="BtnRect"
                  Content="RECT"
                  Style="{StaticResource AnnToolBtn}"
                  Margin="8,0,0,0"
                  Click="BtnRect_OnClick" />
          <Button x:Name="BtnText"
                  Content="TEXT"
                  Style="{StaticResource AnnToolBtn}"
                  Margin="8,0,0,0"
                  Click="BtnText_OnClick" />
          <Button x:Name="BtnUndo"
                  Content="UNDO"
                  Style="{StaticResource AnnToolBtn}"
                  Margin="8,0,0,0"
                  IsEnabled="False"
                  ToolTip="Undo last stroke (Ctrl+Z)"
                  Click="BtnUndo_OnClick" />
          <Button x:Name="BtnRedo"
                  Content="REDO"
                  Style="{StaticResource AnnToolBtn}"
                  Margin="8,0,0,0"
                  IsEnabled="False"
                  ToolTip="Redo (Ctrl+Y)"
                  Click="BtnRedo_OnClick" />
        <Rectangle Width="1"
                   Height="24"
                   Margin="16,0,16,0"
                   Fill="#333333"
                   VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="SwatchRed"
                  Style="{StaticResource SwatchBtn}"
                  Background="#D71921"
                  BorderBrush="#FFFFFF"
                  BorderThickness="2"
                  Margin="0,0,6,0"
                  Click="Swatch_OnClick"
                  Tag="#D71921" />
          <Button x:Name="SwatchWhite"
                  Style="{StaticResource SwatchBtn}"
                  Background="#E8E8E8"
                  BorderBrush="#333333"
                  BorderThickness="1"
                  Margin="0,0,6,0"
                  Click="Swatch_OnClick"
                  Tag="#E8E8E8" />
          <Button x:Name="SwatchGreen"
                  Style="{StaticResource SwatchBtn}"
                  Background="#4A9E5C"
                  BorderBrush="#333333"
                  BorderThickness="1"
                  Margin="0,0,6,0"
                  Click="Swatch_OnClick"
                  Tag="#4A9E5C" />
          <Button x:Name="SwatchAmber"
                  Style="{StaticResource SwatchBtn}"
                  Background="#D4A843"
                  BorderBrush="#333333"
                  BorderThickness="1"
                  Margin="0,0,6,0"
                  Click="Swatch_OnClick"
                  Tag="#D4A843" />
          <Button x:Name="SwatchBlue"
                  Style="{StaticResource SwatchBtn}"
                  Background="#5B9BF6"
                  BorderBrush="#333333"
                  BorderThickness="1"
                  Margin="0,0,6,0"
                  Click="Swatch_OnClick"
                  Tag="#5B9BF6" />
          <Button x:Name="SwatchInk"
                  Style="{StaticResource SwatchBtn}"
                  Background="#1A1A1A"
                  BorderBrush="#333333"
                  BorderThickness="1"
                  Click="Swatch_OnClick"
                  Tag="#1A1A1A" />
        </StackPanel>
        <Rectangle Width="1"
                   Height="24"
                   Margin="16,0,16,0"
                   Fill="#333333"
                   VerticalAlignment="Center" />
        <Grid VerticalAlignment="Center">
          <Button x:Name="BtnPrt"
                  HorizontalAlignment="Left"
                  Content="PRT"
                  Style="{StaticResource AnnToolBtn}"
                  ToolTip="Click: copy full monitor. Hover for region, previous region, or monitor (copies what is on screen)."
                  Click="BtnPrt_OnClick"
                  MouseEnter="BtnPrt_OnMouseEnter"
                  MouseLeave="BtnPrt_OnMouseLeave" />
          <Popup x:Name="PrtMenuPopup"
                 PlacementTarget="{Binding ElementName=BtnPrt}"
                 Placement="Bottom"
                 VerticalOffset="-2"
                 AllowsTransparency="True"
                 StaysOpen="True">
            <Border x:Name="PrtMenuPanel"
                    Background="#111111"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    Padding="6"
                    MinWidth="220"
                    MouseEnter="PrtMenuPanel_OnMouseEnter"
                    MouseLeave="PrtMenuPanel_OnMouseLeave">
              <StackPanel>
                <Button x:Name="PrtMenuRegion"
                        Content="REGION"
                        Style="{StaticResource PrtMenuItem}"
                        Click="PrtMenuRegion_OnClick" />
                <Button x:Name="PrtMenuPrev"
                        Content="PREVIOUS REGION"
                        Style="{StaticResource PrtMenuItem}"
                        Margin="0,6,0,0"
                        Click="PrtMenuPrev_OnClick" />
                <Button x:Name="PrtMenuMonitor"
                        Content="MONITOR"
                        Style="{StaticResource PrtMenuItem}"
                        Margin="0,6,0,0"
                        Click="PrtMenuMonitor_OnClick" />
              </StackPanel>
            </Border>
          </Popup>
        </Grid>
      </StackPanel>
      </Border>
    </Grid>
    <Border x:Name="DrawingHost"
            Grid.Row="1"
            Background="#01000000"
            ClipToBounds="True">
      <Canvas x:Name="DrawingCanvas"
              Background="#01000000"
              ClipToBounds="True"
              MouseLeftButtonDown="DrawingCanvas_OnMouseLeftButtonDown"
              MouseMove="DrawingCanvas_OnMouseMove"
              MouseLeftButtonUp="DrawingCanvas_OnMouseLeftButtonUp" />
    </Border>
  </Grid>
</Window>
