<Window x:Class="CursorShake.RegionPickOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Cursor="Cross"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown"
        MouseMove="Window_OnMouseMove"
        MouseLeftButtonUp="Window_OnMouseLeftButtonUp"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        TextOptions.TextFormattingMode="Display">
  <Grid Background="#01000000">
    <Rectangle Fill="#99000000"
               IsHitTestVisible="True" />
    <Canvas x:Name="OverlayCanvas"
            Background="Transparent"
            ClipToBounds="True">
      <Rectangle x:Name="RubberBand"
                 Visibility="Collapsed"
                 Stroke="#FFFFFF"
                 StrokeThickness="1"
                 StrokeDashArray="4 3"
                 Fill="#15000000"
                 IsHitTestVisible="False" />
    </Canvas>
    <Border x:Name="MagnifierHost"
            Width="140"
            Height="140"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="0"
            Background="#111111"
            BorderBrush="#333333"
            BorderThickness="1"
            IsHitTestVisible="False"
            Panel.ZIndex="100">
      <Border.RenderTransform>
        <TranslateTransform x:Name="MagnifierTranslate" />
      </Border.RenderTransform>
      <Grid Width="140" Height="140">
        <Image x:Name="MagImage"
               Width="120"
               Height="120"
               Margin="10"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />
        <Canvas Width="140"
                Height="140"
                IsHitTestVisible="False">
          <Line X1="70"
                Y1="0"
                X2="70"
                Y2="140"
                Stroke="#D71921"
                StrokeThickness="1" />
          <Line X1="0"
                Y1="70"
                X2="140"
                Y2="70"
                Stroke="#D71921"
                StrokeThickness="1" />
        </Canvas>
      </Grid>
    </Border>
  </Grid>
</Window>
